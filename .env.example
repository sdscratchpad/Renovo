# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.

# GitHub Personal Access Token with 'models:read' scope.
# Required by the diagnosis service to call GPT-4o via GitHub Models.
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_pat_here

# Event store SQLite database path (relative to services/event-store/)
DB_PATH=./data/events.db

# Set to "true" to allow low/medium-risk remediations to auto-execute without approval.
AUTO_MODE=false
